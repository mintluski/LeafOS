#!/bin/sh

# Montar sistemas de arquivos
mount -t proc proc /proc
mount -t sysfs sysfs /sys
mount -t devtmpfs devtmpfs /dev

# Hostname
echo "LeafOS" > /proc/sys/kernel/hostname

# Loopback
ifconfig lo 127.0.0.1 up
for i in 1 2 3 4 5; do
    ifconfig eth0 up 2>/dev/null && break
    sleep 1
done

# Iniciar DHCP em background
/usr/local/bin/net_setup &

# Shell de emergência
exec /bin/sh
